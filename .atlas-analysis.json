  "keyFeatures": [
    "Course browsing with search and category filters",
    "Shopping cart and Stripe payment integration",
    "Separate dashboards for students and instructors",
    "Course creation and content management",
    "Video player integration with React Player",
    "Rating and review system",
    "Firebase storage for media files",
    "Email notifications via EmailJS",
    "User authentication and role-based access"
  ],
  "publicApiSurface": [
    "CartContext - Shopping cart state management",
    "CartProvider - Cart context provider",
    "useCart() - Cart hook for accessing cart state",
    "getAllCourses() - Fetch all courses",
    "getAllCategories() - Fetch all categories",
    "getAllUser() - Fetch all users",
    "getUserById() - Fetch user by ID",
    "getOnSaleCourses() - Fetch discounted courses",
    "postCreateCourse() - Create new course",
    "postPaymentCart() - Process cart payment",
    "updateCourse() - Update course details",
    "updateUser() - Update user information"
  ]
}
